# Template for tests/.env (git-ignored).
#
# The E2E tests don't strictly require these — defaults produce a working test
# vault with fake credentials. Override here only if you want to:
#   - reuse a specific password across debug runs
#   - inspect the generated vault after a failed test
#
# Copy this file to tests/.env and edit as needed.

# Master password for the throwaway vault created per test.
# AIKEY_E2E_PASSWORD=e2e-test-pw

# Fake API key written to the test vault. Never sent to a real provider
# because these tests don't make network calls — the CLI only reads the key
# back for route/activate output. Any non-empty string works.
# AIKEY_E2E_API_KEY=sk-e2e-fake

# Set to 1 to keep the tmpdir after each test (useful for debugging a failure).
# Prints the path to stderr so you can cd in and inspect vault.db.
# AIKEY_E2E_KEEP_TMPDIR=0
